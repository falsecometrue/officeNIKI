{
  "name": "office-to-mdrow",
  "displayName": "office to mdrow",
  "description": "Convert Office files from the VS Code explorer context menu.",
  "version": "0.0.1",
  "publisher": "SAKIYAMA-KANAU",
  "repository": {
    "type": "git",
    "url": "https://github.com/falsecometrue/officeNIKI.git",
    "directory": "office-to-mdrow"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:workbench.view.testing",
    "onCommand:officeToMdrow.convertExcelToDrawio",
    "onCommand:officeToMdrow.convertWordToMarkdown",
    "onCommand:officeToMdrow.convertOfficeFile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "officeToMdrow.convertExcelToDrawio",
        "title": "Convert Excel to Draw.io"
      },
      {
        "command": "officeToMdrow.convertWordToMarkdown",
        "title": "Convert Word to Markdown"
      },
      {
        "command": "officeToMdrow.convertOfficeFile",
        "title": "Convert Office : 選択ファイルを変換"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "officeToMdrow.convertExcelToDrawio",
          "when": "resourceExtname == .xlsx",
          "group": "navigation@50"
        },
        {
          "command": "officeToMdrow.convertWordToMarkdown",
          "when": "resourceExtname == .docx",
          "group": "navigation@51"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test test/*.test.js",
    "test:vscode": "npm run compile && node test/run-vscode-tests.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.26.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "fast-xml-parser": "^5.7.3"
  }
}
