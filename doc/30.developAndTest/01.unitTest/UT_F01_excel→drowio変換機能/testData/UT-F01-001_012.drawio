                    <mxGeometry x="619.95" y="1634" width="295.99" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="cell-C34" value="Note: In Word, you can switch between Flex and Dest. However, to switch to/from an image of the table, you need to re-insert the item." style="text;html=1;fillColor=none;strokeColor=none;align=center;verticalAlign=middle;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="87.96" y="1682" width="236" height="42" as="geometry"/>
